# === Nedvig-1 Environment Variables ===
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://realty:PASSWORD@localhost:5432/realty_db
# For local dev without PostgreSQL:
# DATABASE_URL=sqlite+aiosqlite:///./realty.db

# Security — generate a random key!
SECRET_KEY=CHANGE-ME-openssl-rand-hex-32

# CORS (comma-separated)
CORS_ORIGINS=https://nedvig.ru,http://localhost:3000

# Debug (NEVER true in production)
DEBUG=false

# Elasticsearch (optional, leave empty to disable)
ES_URL=
ES_INDEX=listings

# Redis (optional, leave empty to disable)
REDIS_URL=

# Scraping proxies (comma-separated, optional)
SCRAPE_PROXY_LIST=
