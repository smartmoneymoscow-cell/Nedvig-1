# ═══════════════════════════════════════
# Nedvig-1 / Realty Platform — Environment
# Copy to .env and fill in values
# ═══════════════════════════════════════

# App
APP_NAME=Realty Platform
DEBUG=false

# Database
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://realty:${POSTGRES_PASSWORD}@postgres:5432/realty_db

# Elasticsearch
ES_URL=http://elasticsearch:9200
ES_INDEX=listings

# CORS — comma-separated origins
CORS_ORIGINS=https://nedvig.ru,http://localhost:3000

# Auth
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Scraping
SCRAPE_CONCURRENT_REQUESTS=8
SCRAPE_DOWNLOAD_DELAY=1.5
# Comma-separated proxy list for scraping
SCRAPE_PROXY_LIST=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
